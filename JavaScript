function framing()
{
  if(playerX > rightEnd - Player.offsetWidth)
    {
      playerX = rightEnd - Player.offsetWidth;
    }
  if(playerX < leftEnd)
    {
      playerX = leftEnd;
    }
  if(playerY < topEnd)
    {
      playerY = topEnd;
    }
  if(playerY > bottomEnd - Player.offsetHeight)
    {
      playerY = bottomEnd - Player.offsetHeight;
      velocityY = 0;
    }
}

