//적 생산자
function SpawnEnemy(_width, _height,_left,_hp)
{
  this.root = document.createElement("div");
  gameFrame.appendChild(this.root); 
  this.root.style.width = _width + "px";
  this.root.style.height = _height + "px";
  this.root.style.left = _left + "px";
  this.root.style.zIndex = 1;
  this.root.style.top = bottomEnd - this.root.offsetHeight + "px";
  this.root.style.position = "absolute";
  this.root.style.backgroundColor = "red";
  this.root.style.border = "5px solid yellow";
  this.root.style.borderRadius = "64px"
  
  this.hp = _hp;
  this.isActive = true;
  this.hitCheck = function(_posX , _posY)
  {
    if(this.isActive)
      {
        if (_posX > this.root.offsetLeft 
        &&_posX < this.root.offsetLeft + this.root.offsetWidth)
        {
          if (_posY > this.root.offsetTop 
          &&_posY < this.root.offsetTop + this.root.offsetHeight)
          {
            this.hp -= bulletDmg;
            console.log("명중! 남은체력 : " + this.hp);
            if(this.hp <= 0)
              {
                console.log("죽음");
                this.dead();
              }
          }
        }
      }
    
  }
  this.dead = function()
  {
    this.isActive = false;
    this.root.removeAttribute("style");
    
  }
  
}
//플레이어에 적용되는 힘 계산
function calcForce(deltaTime)
{
  let accelerationX = totalForceX / playerMass;
  let accelerationY = totalForceY / playerMass;
  velocityX += accelerationX * deltaTime;
  velocityY += accelerationY * deltaTime;
  
  if(velocityX > currnetSpeedLimit)
    {
      velocityX = currnetSpeedLimit;
    }
  else if(velocityX < -currnetSpeedLimit)
    {
      velocityX = -currnetSpeedLimit;
    }
  
  
  
  playerX += velocityX * deltaTime;
  playerY += velocityY * deltaTime;
  
}
