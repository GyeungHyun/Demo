      currnetSpeedLimit = runSpeedLimit;
    }
  else
    {
      runMulitiplier = 1;
      currnetSpeedLimit = walkSpeedLimit;
    }
  
  if (downkeys["KeyD"]) {
    totalForceX += MoveSpeed*runMulitiplier;
    
  }

  if (downkeys["KeyA"]) {
    totalForceX -= MoveSpeed*runMulitiplier;
    
  }
  
  if(downkeys["KeyD"] == false && downkeys["KeyA"] == false)
  {
    applyDamping(); 
  }
}
