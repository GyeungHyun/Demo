//벡터 연산
function magnitude(_x,_y) {
  if(Math.sqrt(_x * _x + _y * _y) == NaN)
    {
      console.log("caution");
    }
  return Math.sqrt(_x * _x + _y * _y);
}

function normalize(_x,_y) {
  let length = magnitude(_x,_y);

  return {
    x: _x / length,
    y: _y / length
  };
}

