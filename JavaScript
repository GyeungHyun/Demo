function spawnDot() //조준점의 랜덤 생성 담당
{
  //console.log("점 스폰");
  const radius = 120;
  const angle = Math.random() * Math.PI * 2;
  const distance = Math.random() * radius;
  let randomY = Math.random();
  dot = {
    x: mouse.x + Math.cos(angle) * distance,
    y: mouse.y + Math.sin(angle) * distance,
    vx: 0,
    vy: 0,
    size: 6,
    // 핵심 파라미터
    spring: 0.01,
    damping: 0.9,
  };
  //console.log(dot.x);
  //console.log(dot.y);
}

function followMouse() //조준점이 마우스를 따라다니도록
{
  if (!dot) return;
  //normalize를 안한 건 거리도 반영을 하겠다는 얘기겠지
  const dx = mouse.x-6 - dot.x;
  const dy = mouse.y-6 - dot.y;

  // 스프링 힘
  dot.vx += dx * dot.spring;
  dot.vy += dy * dot.spring;

  // 약간의 랜덤성 (살짝만!)
  dot.vx += (Math.random() - 0.5) * accuracy;
  dot.vy += (Math.random() - 0.5) * accuracy;

  // 감쇠 (마찰)
  dot.vx *= dot.damping;
  dot.vy *= dot.damping;

  dot.x += dot.vx;
  dot.y += dot.vy;
}

function circleFraming()
{
  playerPos.x = playerX + player.offsetWidth/2;
  playerPos.y = playerY + player.offsetHeight/2;
  aimDistanceX = mouse.x - playerPos.x;
  aimDistanceY = mouse.y - playerPos.y;
  let curDistance = magnitude(aimDistanceX,aimDistanceY);
  //console.log(mouse.x,mouse.y);
  //console.log(playerPos.x,playerPos.y);
  //console.log(curDistance);
  //console.log(aimDistanceX,aimDistanceY);
  if(curDistance > range)
    {
      //console.log("거리 제약 작동중");
      let playerToAim = normalize(aimDistanceX,aimDistanceY);
      mouse.x = playerPos.x + playerToAim.x * range;
      mouse.y = playerPos.y + playerToAim.y * range;
    }
  
}

function draw() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  if (dot && downkeys["Space"] == true) {
  ctx.beginPath();
  ctx.arc(dot.x, dot.y, dot.size, 0, Math.PI * 2);
  ctx.fillStyle = "white";
  ctx.fill();
}

// 마우스 표시
ctx.beginPath();
ctx.arc(mouse.x-6, mouse.y-6, 6, 0, Math.PI * 2);
ctx.fillStyle = "blue";
ctx.fill();

if (dot) {
  ctx.beginPath();
  ctx.arc(hitPosX,hitPosY, 6, 0, Math.PI * 2);
  ctx.fillStyle = "grey";
  ctx.fill();
  }
}








function update(currentTime)
{
  let deltaTime = (currentTime - lastTime)/1000;
  lastTime = currentTime;
  totalForceX = 0;
  totalForceY = 0;
  checkDownKeys();
  checkPressedKeys();
  applyGravity();
  calcForce(deltaTime);
  framing();
  circleFraming()
  UpdatePlayerPos();
  followMouse()
  processInteractions();
}
