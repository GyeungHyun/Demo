function getDistance(x1,y1,x2,y2)
{
  return magnitude(x1 - x2, y1 - y2);
}

function updateInteractionHint()
{
  if (!interactionHint) return;
  if (currentInteractable) {
    interactionHint.textContent = "E : " + currentInteractable.name + " 상호작용";
  } else {
    interactionHint.textContent = "";
  }
}

function findNearestInteractable()
{
  currentInteractable = null;
  const playerCenter = {
    x: playerX + Player.offsetWidth / 2,
    y: playerY + Player.offsetHeight / 2
  };

  let closestDistance = Infinity;
  interactables.forEach((item) => {
    const center = item.center();
    const distance = getDistance(playerCenter.x, playerCenter.y, center.x, center.y);
    if (distance <= interactRange && distance < closestDistance) {
      closestDistance = distance;
      currentInteractable = item;
    }
  });

  updateInteractionHint();
}

function processInteractions()
{
  findNearestInteractable();
}

function tryInteract()
{
  if (currentInteractable) {
    currentInteractable.tryInteract();
  }
}

