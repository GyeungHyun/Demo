//속도 감쇠 적용
function applyDamping()
{
  velocityX = velocityX * MoveDamping;
  velocityY = velocityY * MoveDamping;
}
//눌린 키 확인
function checkDownKeys()
{
  if (downkeys["ShiftLeft"])
    {
