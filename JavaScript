//속도 감쇠 적용
function applyDamping()
{
  velocityX = velocityX * MoveDamping;
  velocityY = velocityY * MoveDamping;
}
//눌린 키 확인
function checkDownKeys()
{
  if (downkeys["ShiftLeft"])
    {
      runMulitiplier = 1.5;
      currnetSpeedLimit = runSpeedLimit;
    }
  else
    {
      runMulitiplier = 1;
      currnetSpeedLimit = walkSpeedLimit;
    }
  
  if (downkeys["KeyD"]) {
    totalForceX += MoveSpeed*runMulitiplier;
    
  }

  if (downkeys["KeyA"]) {
    totalForceX -= MoveSpeed*runMulitiplier;
    
  }
  
  if(downkeys["KeyD"] == false && downkeys["KeyA"] == false)
  {
    applyDamping(); 
  }
}
